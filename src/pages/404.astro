---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="404 — Page Not Found | The Log">
  <Header />

  <main class="error-main">
    <div class="container">
      <p class="error-code">// 404</p>
      <h1 class="error-title display-serif">Page not found.</h1>
      <p class="error-sub">This page doesn't exist or may have been moved.</p>
      <a href="/" class="back-link">
        <span class="back-arrow"><Icon name="lucide:arrow-left" size={14} /></span>
        Back to all posts
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .error-main {
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
    opacity: 0.8;
  }

  .error-title {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .error-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    font-weight: 300;
    margin-bottom: var(--space-10);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .back-arrow {
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-3px);
  }
</style>
